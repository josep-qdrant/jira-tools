{
  "mcpServers": {
    "atlassian": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.atlassian.com/v1/mcp/authv2"
      ],
      "disabled": false,
      "autoApprove": [
        "atlassianUserInfo",
        "getAccessibleAtlassianResources",
        "getVisibleJiraProjects",
        "getJiraProjectIssueTypesMetadata",
        "getJiraIssue",
        "searchJiraIssuesUsingJql",
        "getJiraIssueRemoteIssueLinks",
        "lookupJiraAccountId",
        "getConfluencePage",
        "searchConfluenceUsingCql"
      ]
    },
    "figma": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.figma.com/mcp"
      ],
      "disabled": false,
      "autoApprove": [
        "get_metadata",
        "get_screenshot",
        "get_design_context",
        "get_variable_defs",
        "get_code_connect_map"
      ]
    },
    "notion": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.notion.com/mcp"
      ],
      "disabled": false,
      "autoApprove": [
        "notion-search",
        "notion-fetch",
        "notion-get-comments"
      ]
    },
    "engram": {
      "command": "engram",
      "args": ["mcp"],
      "disabled": false,
      "autoApprove": [
        "mem_search",
        "mem_context",
        "mem_get_observation",
        "mem_current_project",
        "mem_save",
        "mem_save_prompt",
        "mem_session_start",
        "mem_session_summary",
        "mem_session_end",
        "mem_suggest_topic_key",
        "mem_judge"
      ]
    }
  }
}